##
## JeryMotro Platform — Fichier d'environnement Symfony
## Copier ce fichier en ".env" et NE JAMAIS committer le .env
##

# ─── Symfony Core ────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=changez_ce_secret_generez_avec_openssl_rand_hex_16
APP_DEBUG=true

# ─── Base de données Supabase ─────────────────────────────────
# Trouver dans : Supabase Dashboard → Settings → Database → URI
# Remplacer VOTRE_MOT_DE_PASSE et VOTRE_PROJECT_REF
DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_PROJECT_REF.supabase.co:5432/postgres?sslmode=require&serverVersion=15"

# ─── n8n Webhook (Hugging Face Spaces) ───────────────────────
# Local  : http://localhost:5678/webhook/madfire-alert
# Cloud  : https://rtsikynyantsa-jerymotro-pipeline.hf.space/webhook/madfire-alert

# Clé d'authentification exigée par Hugging Face
HF_TOKEN="hf_votre_token_huggingface_ici"

N8N_WEBHOOK_URL="https://rtsikynyantsa-jerymotro-pipeline.hf.space/webhook/madfire-alert"
N8N_AGENT_WEBHOOK_URL="https://rtsikynyantsa-jerymotro-pipeline.hf.space/webhook/jeryMotro-agent"
