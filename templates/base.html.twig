<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}JeryMotro Platform{% endblock %}</title>
    <link rel="icon" type="image/png" href="https://i.ibb.co/Nw10cBf/logo.jpg">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-w: 260px;
            --fire-red: #ff3333;
            --fire-orange: #ff7700;
            --fire-dark: #0a110d;
            --fire-mid: #132018;
            --bg-main: #060907;
            --text-main: #e2ede5;
            --text-muted: #8b9d92;
            --border-color: rgba(255,255,255,.06);
            --topbar-h: 64px;
        }

        /* ── Global & Typography ─────────────────────────── */
        body {
            background-color: var(--bg-main);
            background: linear-gradient(135deg, rgba(6,9,7,.94) 0%, rgba(10,17,13,.98) 100%),
                        url('https://i.ibb.co/d4YfJ7F7/sidebar-bg.jpg') no-repeat center center / cover fixed;
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            overflow-x: hidden;
        }

        /* ── Custom Scrollbar Globally ───────────────────── */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,.2); }
        ::-webkit-scrollbar-thumb { background: rgba(255,51,51,.3); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,51,51,.6); }

        @keyframes subtleFadeIn {
            0%   { opacity: 0; transform: translateY(15px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes slideInLeft {
            from { transform: translateX(-100%); }
            to   { transform: translateX(0); }
        }
        @keyframes pulseGlow {
            0%   { box-shadow: 0 0 10px rgba(255,51,51,.2); }
            50%  { box-shadow: 0 0 20px rgba(255,51,51,.5); }
            100% { box-shadow: 0 0 10px rgba(255,51,51,.2); }
        }

        /* ── Sidebar ─────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: linear-gradient(180deg, rgba(10,17,13,.96) 0%, rgba(6,9,7,.88) 100%),
                        url('https://i.ibb.co/d4YfJ7F7/sidebar-bg.jpg') no-repeat center bottom / cover;
            background-color: var(--fire-dark);
            color: var(--text-main);
            position: fixed;
            top: 0; left: 0; bottom: 0;
            display: flex;
            flex-direction: column;
            z-index: 1050;
            box-shadow: 4px 0 20px rgba(0,0,0,.6);
            backdrop-filter: blur(10px);
            border-right: 1px solid var(--border-color);
            transition: transform .3s cubic-bezier(.4,0,.2,1);
            overflow-y: auto;
        }
        .sidebar-brand {
            padding: 1.5rem 1.5rem 1.2rem;
            border-bottom: 1px solid var(--border-color);
            background: rgba(0,0,0,.2);
            flex-shrink: 0;
        }
        .sidebar-brand h1 {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--fire-red);
            margin: 0;
            letter-spacing: .5px;
            text-transform: uppercase;
            text-shadow: 0 0 12px rgba(255,51,51,.4);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-brand small {
            font-size: .72rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 4px;
            display: block;
        }
        .sidebar-nav { padding: 1rem 0; flex: 1; }
        .nav-section {
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            padding: 1rem 1.5rem .4rem;
            font-weight: 700;
        }
        .sidebar-nav .nav-link {
            color: rgba(226,237,229,.7);
            padding: .75rem 1.5rem;
            border-radius: 0;
            font-size: .88rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: .85rem;
            transition: all .3s cubic-bezier(0.2, 0.8, 0.2, 1);
            position: relative;
        }
        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            background: linear-gradient(90deg, rgba(255,51,51,.15) 0%, transparent 100%);
            color: #fff;
            padding-left: 1.8rem; /* Translate right effect */
        }
        .sidebar-nav .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 0; bottom: 0;
            width: 4px;
            background: var(--fire-red);
            box-shadow: 0 0 15px var(--fire-red);
        }
        .sidebar-nav .nav-link i {
            font-size: 1.1rem;
            width: 22px;
            text-align: center;
            color: var(--fire-orange);
            opacity: .8;
        }
        .sidebar-nav .nav-link:hover i,
        .sidebar-nav .nav-link.active i { opacity: 1; color: var(--fire-red); }
        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border-color);
            font-size: .72rem;
            color: var(--text-muted);
            background: rgba(0,0,0,.3);
            flex-shrink: 0;
        }

        /* ── Sidebar Backdrop (mobile) ───────────────────── */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.6);
            z-index: 1040;
            backdrop-filter: blur(2px);
            opacity: 0;
            transition: opacity .3s;
        }
        .sidebar-backdrop.show {
            display: block;
            opacity: 1;
        }

        /* ── Main ────────────────────────────────────────── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            background: transparent;
            color: var(--text-main);
            transition: margin-left .3s cubic-bezier(.4,0,.2,1);
        }
        /* Cascading entrance animations for page content */
        .page-body > * {
            opacity: 0;
            animation: subtleFadeIn .6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }
        .page-body > *:nth-child(1) { animation-delay: 0.05s; }
        .page-body > *:nth-child(2) { animation-delay: 0.15s; }
        .page-body > *:nth-child(3) { animation-delay: 0.25s; }
        .page-body > *:nth-child(4) { animation-delay: 0.35s; }
        .page-body > *:nth-child(5) { animation-delay: 0.45s; }
        .page-body > *:nth-child(6) { animation-delay: 0.55s; }
        .topbar {
            background: rgba(10,17,13,.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding: 0 1.5rem;
            height: var(--topbar-h);
            border-bottom: 1px solid rgba(255,255,255,0.03);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1030;
            box-shadow: 0 4px 30px rgba(0,0,0,0.5);
            gap: 1rem;
        }
        .topbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
            min-width: 0;
        }
        .topbar h2 {
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0;
            color: #fff;
            letter-spacing: .5px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .topbar-meta {
            font-size: .72rem;
            color: #4a5568;
            white-space: nowrap;
        }

        /* ── Hamburger button ────────────────────────────── */
        .btn-hamburger {
            display: none;
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            border-radius: 8px;
            padding: .4rem .6rem;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all .2s;
            flex-shrink: 0;
        }
        .btn-hamburger:hover {
            background: rgba(255,51,51,.1);
            border-color: var(--fire-red);
            color: var(--fire-red);
        }

        /* ── Sidebar close button (mobile) ───────────────── */
        .btn-sidebar-close {
            display: none;
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(255,51,51,.15);
            border: 1px solid rgba(255,51,51,.3);
            color: var(--fire-red);
            border-radius: 8px;
            padding: .3rem .5rem;
            font-size: 1rem;
            cursor: pointer;
            z-index: 1;
        }

        .page-body {
            padding: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── Stat cards ───────────────────────────────────── */
        .stat-card {
            background: linear-gradient(145deg, var(--fire-mid) 0%, rgba(10,17,13,0.95) 100%);
            border: 1px solid rgba(255,255,255,0.03);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1.2rem;
            box-shadow: 0 8px 32px rgba(0,0,0,.3);
            transition: all .3s cubic-bezier(0.2, 0.8, 0.2, 1);
            position: relative;
            overflow: hidden;
            height: 100%;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 4px; height: 100%;
            background: transparent;
            transition: all .3s;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,.5);
            border-color: rgba(255,255,255,.08);
        }
        .stat-card:hover::before { background: var(--fire-orange); box-shadow: 0 0 15px var(--fire-orange); }
        .stat-icon {
            width: 64px; height: 64px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            flex-shrink: 0;
            transition: transform .3s;
        }
        .stat-card:hover .stat-icon { transform: scale(1.1); }
        .stat-icon.red    { background: rgba(255,51,51,.1);  color: var(--fire-red);    box-shadow: inset 0 0 20px rgba(255,51,51,.15); }
        .stat-icon.orange { background: rgba(255,119,0,.1);  color: var(--fire-orange); box-shadow: inset 0 0 20px rgba(255,119,0,.15); }
        .stat-icon.blue   { background: rgba(33,150,243,.1); color: #42a5f5;          box-shadow: inset 0 0 20px rgba(33,150,243,.15); }
        .stat-icon.green  { background: rgba(76,175,80,.1);  color: #66bb6a;          box-shadow: inset 0 0 20px rgba(76,175,80,.15); }
        .stat-val { 
            font-size: 2.2rem; 
            font-weight: 800; 
            line-height: 1.1; 
            margin-bottom: .2rem;
            background: linear-gradient(to right, #fff, #a8b2d1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .stat-lbl { font-size: .8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

        /* ── Tables ───────────────────────────────────────── */
        .dark-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: .88rem; }
        .dark-table thead th {
            background: rgba(0,0,0,.3);
            color: var(--text-muted);
            padding: 1rem;
            text-transform: uppercase;
            font-size: .72rem;
            letter-spacing: 1px;
            border-bottom: 2px solid var(--border-color);
            border-top: 1px solid var(--border-color);
            font-weight: 700;
        }
        .dark-table thead th:first-child { border-top-left-radius: 8px; border-left: 1px solid var(--border-color); }
        .dark-table thead th:last-child  { border-top-right-radius: 8px; border-right: 1px solid var(--border-color); }
        .dark-table tbody tr { transition: background .2s; }
        .dark-table tbody tr:hover { background: rgba(255,255,255,.03); }
        .dark-table td {
            padding: .85rem 1rem;
            color: var(--text-main);
            vertical-align: middle;
            border-bottom: 1px solid var(--border-color);
        }
        .dark-table tbody tr td:first-child { border-left: 1px solid var(--border-color); }
        .dark-table tbody tr td:last-child  { border-right: 1px solid var(--border-color); }
        .dark-table tbody tr:last-child td:first-child { border-bottom-left-radius: 8px; }
        .dark-table tbody tr:last-child td:last-child  { border-bottom-right-radius: 8px; }

        /* ── Cards ────────────────────────────────────────── */
        .dark-card {
            background: rgba(19,32,24,0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,.4);
            overflow: hidden;
            margin-bottom: 1.5rem;
        }
        .dark-card-header {
            background: rgba(0,0,0,.3);
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            font-size: .95rem;
            font-weight: 700;
            color: #fff;
            display: flex;
            align-items: center;
            gap: .8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ── Forms ────────────────────────────────────────── */
        .form-control, .form-select {
            background: rgba(0,0,0,.25) !important;
            border: 1px solid var(--border-color) !important;
            color: var(--text-main) !important;
            border-radius: 8px;
            padding: .7rem 1rem;
            font-size: .9rem;
            transition: all .2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--fire-orange) !important;
            box-shadow: 0 0 0 3px rgba(255,119,0,.15) !important;
            background: rgba(0,0,0,.4) !important;
        }
        label { color: var(--text-muted); font-size: .85rem; margin-bottom: .4rem; font-weight: 500; }

        /* ── Badges ───────────────────────────────────────── */
        .badge { font-size: .75rem; padding: .4em .7em; border-radius: 6px; font-weight: 600; letter-spacing: .3px; }
        .badge.bg-danger  { background-color: var(--fire-red) !important; box-shadow: 0 0 10px rgba(255,51,51,.5); }
        .badge.bg-warning { background-color: var(--fire-orange) !important; color: #000 !important; box-shadow: 0 0 10px rgba(255,119,0,.4); }

        /* ── Buttons ──────────────────────────────────────── */
        .btn-fire {
            background: linear-gradient(135deg, var(--fire-orange), var(--fire-red));
            border: none;
            color: #fff;
            font-weight: 700;
            padding: .6rem 1.5rem;
            border-radius: 8px;
            font-size: .9rem;
            transition: all .2s;
            box-shadow: 0 4px 15px rgba(255,51,51,.3);
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .btn-fire:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255,51,51,.5);
            color: #fff;
        }

        /* ── Flashes ──────────────────────────────────────── */
        .alert { border-radius: 10px; border: 1px solid transparent; backdrop-filter: blur(5px); }
        .alert-success { background: rgba(76,175,80,.15);  border-color: rgba(76,175,80,.4);  color: #a5d6a7; }
        .alert-danger  { background: rgba(255,51,51,.15);  border-color: rgba(255,51,51,.4);  color: #ffcdd2; }
        .alert-warning { background: rgba(255,152,0,.15);  border-color: rgba(255,152,0,.4);  color: #ffe0b2; }
        .alert-info    { background: rgba(33,150,243,.15); border-color: rgba(33,150,243,.4); color: #bbdefb; }

        /* ════════════════════════════════════════════════════
           RESPONSIVE — Tablet (< 992px)
        ════════════════════════════════════════════════════ */
        @media (max-width: 991.98px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
                animation: slideInLeft .3s cubic-bezier(.4,0,.2,1);
            }
            .btn-hamburger {
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .btn-sidebar-close {
                display: block;
            }
            .main-wrap {
                margin-left: 0 !important;
            }
            .page-body {
                padding: 1.25rem;
            }
        }

        /* ════════════════════════════════════════════════════
           RESPONSIVE — Mobile (< 576px)
        ════════════════════════════════════════════════════ */
        @media (max-width: 575.98px) {
            :root { --sidebar-w: 100vw; }
            .page-body { padding: 1rem; }
            .topbar { padding: 0 1rem; }
            .topbar h2 { font-size: 1rem; }
            .topbar-meta { display: none; }
            .stat-val { font-size: 1.5rem; }
            .stat-icon { width: 46px; height: 46px; font-size: 1.3rem; }
            .stat-card { padding: 1.1rem; gap: .9rem; }
            .dark-card-header { font-size: .82rem; padding: 1rem; }
            .dark-table { font-size: .8rem; }
            .dark-table thead th,
            .dark-table td { padding: .65rem .75rem; }
        }

        /* ════════════════════════════════════════════════════
           Table: horizontal scroll on small screens
        ════════════════════════════════════════════════════ */
        .table-responsive-dark {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 12px;
        }
        .table-responsive-dark::-webkit-scrollbar { height: 4px; }
        .table-responsive-dark::-webkit-scrollbar-track { background: transparent; }
        .table-responsive-dark::-webkit-scrollbar-thumb { background: var(--fire-orange); border-radius: 2px; }
    </style>

    {% block head_extra %}{% endblock %}
</head>
<body>

<!-- ── Sidebar Backdrop (mobile overlay) ──────────── -->
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<!-- ── Sidebar ─────────────────────────────────────────── -->
<nav class="sidebar" id="sidebar">
    <!-- Close button (mobile only) -->
    <button class="btn-sidebar-close" id="btnSidebarClose" aria-label="Fermer le menu">
        <i class="bi bi-x-lg"></i>
    </button>

    <div class="sidebar-brand">
        <h1>
            <img src="https://i.ibb.co/Nw10cBf/logo.jpg" alt="Logo JeryMotro"
                 style="width:32px;height:32px;border-radius:8px;flex-shrink:0;">
            JeryMotro
        </h1>
        <small>Feux de brousse — Madagascar</small>
    </div>

    <div class="sidebar-nav">
        <div class="nav-section">Principal</div>
        <a href="{{ path('dashboard_index') }}"
           class="nav-link {% if app.current_route starts with 'dashboard' %}active{% endif %}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section">Gestion</div>
        <a href="{{ path('alert_index') }}"
           class="nav-link {% if app.current_route starts with 'alert' %}active{% endif %}">
            <i class="bi bi-bell-fill"></i> Alertes
        </a>
        <a href="{{ path('user_index') }}"
           class="nav-link {% if app.current_route starts with 'user' %}active{% endif %}">
            <i class="bi bi-people-fill"></i> Utilisateurs
        </a>

        <div class="nav-section">Intelligence</div>
        <a href="{{ path('agent_index') }}"
           class="nav-link {% if app.current_route starts with 'agent' %}active{% endif %}">
            <i class="bi bi-robot"></i> Agent IA
        </a>

        <div class="nav-section">Export</div>
        <a href="{{ path('dashboard_export_pdf') }}" class="nav-link" target="_blank">
            <i class="bi bi-file-earmark-pdf"></i> Rapport PDF
        </a>
    </div>

    <div class="sidebar-footer">
        Mémoire L3 · Génie Logiciel<br>
        23/02 → 23/05/2026
    </div>
</nav>

<!-- ── Main ───────────────────────────────────────────── -->
<div class="main-wrap" id="mainWrap">
    <div class="topbar">
        <div class="topbar-left">
            <!-- Hamburger — visible only on tablet/mobile -->
            <button class="btn-hamburger" id="btnHamburger" aria-label="Ouvrir le menu" aria-expanded="false">
                <i class="bi bi-list"></i>
            </button>
            <h2>{% block page_title %}JeryMotro{% endblock %}</h2>
        </div>
        <span class="topbar-meta">
            Pipeline FIRMS · n8n · Supabase
        </span>
    </div>

    <div class="page-body {% block page_body_class %}{% endblock %}">
        <!-- Flash messages -->
        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mb-3" role="alert">
                    {{ msg }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block content %}{% endblock %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    const sidebar   = document.getElementById('sidebar');
    const backdrop  = document.getElementById('sidebarBackdrop');
    const btnOpen   = document.getElementById('btnHamburger');
    const btnClose  = document.getElementById('btnSidebarClose');

    function openSidebar() {
        sidebar.classList.add('open');
        backdrop.classList.add('show');
        btnOpen.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        sidebar.classList.remove('open');
        backdrop.classList.remove('show');
        btnOpen.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
    }

    btnOpen.addEventListener('click', openSidebar);
    btnClose.addEventListener('click', closeSidebar);
    backdrop.addEventListener('click', closeSidebar);

    // Close on nav-link click (mobile UX)
    sidebar.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 992) closeSidebar();
        });
    });

    // Keyboard: ESC closes sidebar
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && sidebar.classList.contains('open')) closeSidebar();
    });
})();
</script>
{% block scripts %}{% endblock %}
</body>
</html>
