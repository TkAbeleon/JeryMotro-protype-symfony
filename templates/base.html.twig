<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}JeryMotro Platform{% endblock %}</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-w: 240px;
            --fire-red:  #e63946;
            --fire-dark: #1a1a2e;
            --fire-mid:  #16213e;
        }

        /* ── Sidebar ─────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--fire-dark);
            color: #ccd6f6;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }
        .sidebar-brand {
            padding: 1.4rem 1.2rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-brand h1 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--fire-red);
            margin: 0;
            letter-spacing: .5px;
        }
        .sidebar-brand small {
            font-size: .7rem;
            color: #8892b0;
        }
        .sidebar-nav { padding: .5rem 0; flex: 1; }
        .nav-section {
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #4a5568;
            padding: .8rem 1.2rem .3rem;
        }
        .sidebar-nav .nav-link {
            color: #8892b0;
            padding: .55rem 1.2rem;
            border-radius: 0;
            font-size: .85rem;
            display: flex;
            align-items: center;
            gap: .55rem;
            transition: all .15s;
        }
        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            background: rgba(230,57,70,.12);
            color: #fff;
            border-left: 3px solid var(--fire-red);
            padding-left: calc(1.2rem - 3px);
        }
        .sidebar-nav .nav-link i { font-size: 1rem; width: 20px; text-align: center; }
        .sidebar-footer {
            padding: .8rem 1.2rem;
            border-top: 1px solid rgba(255,255,255,.08);
            font-size: .72rem;
            color: #4a5568;
        }

        /* ── Main ────────────────────────────────────────── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            background: #0f0f1a;
            color: #e0e0e0;
        }
        .topbar {
            background: var(--fire-mid);
            padding: .85rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .topbar h2 {
            font-size: 1rem;
            font-weight: 600;
            margin: 0;
            color: #ccd6f6;
        }
        .page-body { padding: 1.5rem; }

        /* ── Stat cards ───────────────────────────────────── */
        .stat-card {
            background: var(--fire-mid);
            border: 1px solid rgba(255,255,255,.06);
            border-radius: 10px;
            padding: 1.2rem 1.4rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }
        .stat-icon.red    { background: rgba(230,57,70,.18);  color: var(--fire-red); }
        .stat-icon.orange { background: rgba(255,152,0,.18);  color: #ff9800; }
        .stat-icon.blue   { background: rgba(33,150,243,.18); color: #2196f3; }
        .stat-icon.green  { background: rgba(76,175,80,.18);  color: #4caf50; }
        .stat-val { font-size: 1.7rem; font-weight: 700; color: #fff; line-height: 1; }
        .stat-lbl { font-size: .75rem; color: #8892b0; margin-top: 2px; }

        /* ── Tables ───────────────────────────────────────── */
        .dark-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
        .dark-table thead th {
            background: rgba(255,255,255,.04);
            color: #8892b0;
            padding: .6rem .9rem;
            text-transform: uppercase;
            font-size: .68rem;
            letter-spacing: .8px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .dark-table tbody tr { border-bottom: 1px solid rgba(255,255,255,.04); }
        .dark-table tbody tr:hover { background: rgba(255,255,255,.03); }
        .dark-table td { padding: .6rem .9rem; color: #ccd6f6; vertical-align: middle; }

        /* ── Cards ────────────────────────────────────────── */
        .dark-card {
            background: var(--fire-mid);
            border: 1px solid rgba(255,255,255,.06);
            border-radius: 10px;
            overflow: hidden;
        }
        .dark-card-header {
            padding: .9rem 1.2rem;
            border-bottom: 1px solid rgba(255,255,255,.06);
            font-size: .85rem;
            font-weight: 600;
            color: #ccd6f6;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        /* ── Forms ────────────────────────────────────────── */
        .form-control, .form-select {
            background: #1e2030 !important;
            border: 1px solid rgba(255,255,255,.12) !important;
            color: #ccd6f6 !important;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--fire-red) !important;
            box-shadow: 0 0 0 2px rgba(230,57,70,.2) !important;
        }
        label { color: #8892b0; font-size: .83rem; margin-bottom: .3rem; }

        /* ── Badges ───────────────────────────────────────── */
        .badge { font-size: .7rem; }

        /* ── Btn primary ──────────────────────────────────── */
        .btn-fire {
            background: var(--fire-red);
            border: none;
            color: #fff;
            font-weight: 600;
            padding: .5rem 1.2rem;
            border-radius: 6px;
            font-size: .85rem;
            transition: opacity .15s;
        }
        .btn-fire:hover { opacity: .85; color: #fff; }

        /* ── Flashes ──────────────────────────────────────── */
        .alert-success { background: rgba(76,175,80,.12);  border-color: rgba(76,175,80,.3);  color: #81c784; }
        .alert-danger  { background: rgba(230,57,70,.12);  border-color: rgba(230,57,70,.3);  color: #e57373; }
        .alert-warning { background: rgba(255,152,0,.12);  border-color: rgba(255,152,0,.3);  color: #ffb74d; }
        .alert-info    { background: rgba(33,150,243,.12); border-color: rgba(33,150,243,.3); color: #64b5f6; }
    </style>

    {% block head_extra %}{% endblock %}
</head>
<body>

<!-- ── Sidebar ─────────────────────────────────────────── -->
<nav class="sidebar">
    <div class="sidebar-brand">
        <h1>🔥 JeryMotro</h1>
        <small>Feux de brousse — Madagascar</small>
    </div>

    <div class="sidebar-nav">
        <div class="nav-section">Principal</div>
        <a href="{{ path('dashboard_index') }}"
           class="nav-link {% if app.current_route starts with 'dashboard' %}active{% endif %}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section">Gestion</div>
        <a href="{{ path('alert_index') }}"
           class="nav-link {% if app.current_route starts with 'alert' %}active{% endif %}">
            <i class="bi bi-bell-fill"></i> Alertes
        </a>
        <a href="{{ path('user_index') }}"
           class="nav-link {% if app.current_route starts with 'user' %}active{% endif %}">
            <i class="bi bi-people-fill"></i> Utilisateurs
        </a>

        <div class="nav-section">Intelligence</div>
        <a href="{{ path('agent_index') }}"
           class="nav-link {% if app.current_route starts with 'agent' %}active{% endif %}">
            <i class="bi bi-robot"></i> Agent IA
        </a>

        <div class="nav-section">Export</div>
        <a href="{{ path('dashboard_export_pdf') }}" class="nav-link" target="_blank">
            <i class="bi bi-file-earmark-pdf"></i> Rapport PDF
        </a>
    </div>

    <div class="sidebar-footer">
        Mémoire L3 · Génie Logiciel<br>
        23/02 → 23/05/2026
    </div>
</nav>

<!-- ── Main ───────────────────────────────────────────── -->
<div class="main-wrap">
    <div class="topbar">
        <h2>{% block page_title %}JeryMotro{% endblock %}</h2>
        <span style="font-size:.75rem; color:#4a5568;">
            Pipeline FIRMS · n8n · Supabase
        </span>
    </div>

    <div class="page-body">
        <!-- Flash messages -->
        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mb-3" role="alert">
                    {{ msg }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block content %}{% endblock %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
