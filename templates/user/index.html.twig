{% extends 'base.html.twig' %}
{% block title %}Utilisateurs — JeryMotro{% endblock %}
{% block page_title %}<i class="bi bi-people-fill"></i> Utilisateurs{% endblock %}

{% block content %}

<div style="display:flex;justify-content:flex-end;margin-bottom:1rem">
    <a href="{{ path('user_new') }}" class="btn-fire btn">
        <i class="bi bi-person-plus-fill"></i> Nouvel utilisateur
    </a>
</div>

<div class="dark-card">
    <div class="dark-card-header d-flex align-items-center gap-3">
        <div style="width:32px;height:32px;border-radius:8px;background:rgba(33,150,243,.1);display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-people" style="color:#42a5f5;filter:drop-shadow(0 0 5px #42a5f5)"></i>
        </div>
        <span>Liste des utilisateurs ({{ users|length }})</span>
    </div>

    <div class="table-responsive-dark">
        <table class="dark-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Alertes</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td style="color:#4a5568">{{ user.id }}</td>
                    <td><strong style="color:#ccd6f6">{{ user.name }}</strong></td>
                    <td style="color:#8892b0">{{ user.email }}</td>
                    <td style="color:#8892b0">{{ user.phone ?? '—' }}</td>
                    <td>
                        <span class="badge bg-secondary">{{ user.alertsCount }}</span>
                    </td>
                    <td style="font-size:.78rem">{{ user.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <div style="display:flex;gap:.4rem">
                            <a href="{{ path('user_edit', {id: user.id}) }}"
                               class="btn btn-sm btn-outline-info" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form method="post" action="{{ path('user_delete', {id: user.id}) }}"
                                  onsubmit="return confirm('Supprimer {{ user.name }} ?')">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;color:#4a5568;padding:2.5rem">
                        <i class="bi bi-person-x" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                        Aucun utilisateur.<br>
                        <a href="{{ path('user_new') }}" style="color:#e63946">Créer le premier</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
