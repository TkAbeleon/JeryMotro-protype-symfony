{% extends 'base.html.twig' %}

{% block title %}Dashboard — JeryMotro{% endblock %}
{% block page_title %}<i class="bi bi-speedometer2"></i> Dashboard{% endblock %}

{% block content %}

{# ── Accueil / Description ───────────────────────────────── #}
<div class="dark-card mb-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(10,17,13,.92) 0%, rgba(19,32,24,.85) 100%); padding: clamp(1.5rem, 4vw, 3rem); border-left: 4px solid var(--fire-red); box-shadow: 0 10px 40px rgba(0,0,0,0.5), inset 4px 0 20px rgba(255,51,51,0.2);">
    <div class="d-flex align-items-center justify-content-between gap-4 flex-wrap">
        <div style="z-index:2; min-width:0; flex:1">
            <h3 style="color:#fff; font-weight:800; font-size:clamp(1.5rem,3vw,2.2rem); margin-bottom:.8rem; letter-spacing:-0.5px; text-shadow:0 0 20px rgba(255,255,255,.2);">
                Surveillance Stratégique — JeryMotro <i class="bi bi-fire" style="color:var(--fire-red); filter:drop-shadow(0 0 8px var(--fire-red));"></i>
            </h3>
            <p style="color:#a8b2d1; font-size:clamp(.95rem,2vw,1.1rem); line-height:1.6; margin-bottom:0;">
                <strong>JeryMotro</strong> est une plateforme de télédétection spatiale dédiée à la surveillance en temps réel des feux de brousse à Madagascar.
            </p>
        </div>
        <div class="d-none d-lg-flex align-items-center justify-content-center flex-shrink-0" style="z-index:2; width:100px; height:100px; background:rgba(0,0,0,.3); border-radius:50%; border:1px solid rgba(255,255,255,.1); box-shadow:inset 0 0 20px rgba(255,51,51,.2);">
            <i class="bi bi-globe-africa" style="font-size:3rem; color:rgba(255,51,51,.8); text-shadow:0 0 20px rgba(255,51,51,.5);"></i>
        </div>
    </div>
</div>

{# ── Stat Cards ──────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-fire"></i></div>
            <div>
                <div class="stat-val">{{ today_count }}</div>
                <div class="stat-lbl">Détections aujourd'hui</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-lightning-fill"></i></div>
            <div>
                <div class="stat-val">{{ max_frp }} <small style="font-size:.9rem">MW</small></div>
                <div class="stat-lbl">FRP max (24h)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="stat-val">{{ total_users }}</div>
                <div class="stat-lbl">Utilisateurs enregistrés</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-bell-fill"></i></div>
            <div>
                <div class="stat-val">{{ sent_alerts }}</div>
                <div class="stat-lbl">Alertes envoyées</div>
            </div>
        </div>
    </div>
</div>

{# ── Charts ──────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,51,51,.1);display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-bar-chart-fill" style="color:var(--fire-red);filter:drop-shadow(0 0 5px var(--fire-red))"></i>
                </div>
                Détections par jour — 7 derniers jours
            </div>
            <div style="padding:1.5rem">
                <canvas id="dailyChart" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,119,0,.1);display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-pie-chart-fill" style="color:var(--fire-orange);filter:drop-shadow(0 0 5px var(--fire-orange))"></i>
                </div>
                MODIS vs VIIRS (24h)
            </div>
            <div style="padding:1.5rem; display:flex; align-items:center; justify-content:center; min-height:200px">
                <canvas id="sourceChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

{# ── Hotspots table ──────────────────────────────────────── #}
<div class="dark-card">
    <div class="dark-card-header d-flex flex-wrap align-items-center justify-content-between gap-3">
        <span class="d-flex align-items-center gap-2">
            <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,51,51,.1);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-geo-alt-fill" style="color:var(--fire-red);filter:drop-shadow(0 0 5px var(--fire-red))"></i>
            </div>
            Hotspots récents (FRP > 50 MW — 48h)
        </span>
        <a href="{{ path('dashboard_export_pdf') }}" target="_blank" class="btn-fire btn btn-sm d-inline-flex align-items-center gap-2">
            <i class="bi bi-file-earmark-pdf"></i>
            <span class="d-none d-sm-inline">Exporter PDF</span>
        </a>
    </div>

    <div class="table-responsive-dark">
        <table class="dark-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Source</th>
                    <th>Satellite</th>
                    <th>Latitude</th>
                    <th>Longitude</th>
                    <th>FRP (MW)</th>
                    <th>Risque</th>
                    <th>Date acquisition</th>
                    <th>J/N</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for d in hotspots %}
                <tr>
                    <td style="color:#4a5568">{{ d.id }}</td>
                    <td><span class="badge bg-secondary">{{ d.source }}</span></td>
                    <td>{{ d.satellite ?? '—' }}</td>
                    <td style="font-family:monospace">{{ d.latitude|number_format(4) }}</td>
                    <td style="font-family:monospace">{{ d.longitude|number_format(4) }}</td>
                    <td>
                        <strong style="color:{% if d.frp > 100 %}#ff3333{% elseif d.frp > 50 %}#ff7700{% else %}#42a5f5{% endif %}">
                            {{ d.frp|number_format(1) }}
                        </strong>
                    </td>
                    <td>
                        <span class="badge bg-{{ d.riskBadgeClass }}" style="box-shadow: 0 0 10px var(--bs-{{ d.riskBadgeClass }});">
                            {{ d.riskLabel }}
                        </span>
                    </td>
                    <td>{{ d.acqDatetime|date('d/m/Y H:i') }}</td>
                    <td>{% if d.daynight == 'D' %}☀️{% else %}🌙{% endif %}</td>
                    <td>
                        <a href="{{ path('alert_new') }}"
                           class="btn btn-sm btn-outline-danger"
                           title="Créer une alerte">
                            <i class="bi bi-bell-fill"></i>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="10" style="text-align:center;color:#4a5568;padding:2rem">
                        <i class="bi bi-check-circle" style="font-size:1.5rem"></i><br>
                        Aucun hotspot (FRP > 50 MW) dans les dernières 48h.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#8892b0';
Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';

// ── Détections par jour ──────────────────────────────────
new Chart(document.getElementById('dailyChart'), {
    type: 'bar',
    data: {
        labels: {{ chart_labels|raw }},
        datasets: [{
            label: 'Détections',
            data:  {{ chart_counts|raw }},
            backgroundColor: 'rgba(255,51,51,0.6)',
            borderColor:     'rgba(255,51,51,1)',
            borderWidth: 1,
            borderRadius: 4,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { precision: 0 }, beginAtZero: true }
        }
    }
});

// ── MODIS vs VIIRS ───────────────────────────────────────
new Chart(document.getElementById('sourceChart'), {
    type: 'doughnut',
    data: {
        labels: {{ source_labels|raw }},
        datasets: [{
            data:            {{ source_counts|raw }},
            backgroundColor: ['rgba(255,51,51,0.7)', 'rgba(255,119,0,0.7)', 'rgba(66,165,245,0.7)'],
            borderColor:     ['#ff3333', '#ff7700', '#42a5f5'],
            borderWidth: 2,
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } }
        },
        cutout: '65%'
    }
});
</script>
{% endblock %}
