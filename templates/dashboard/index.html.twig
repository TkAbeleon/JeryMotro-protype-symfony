{% extends 'base.html.twig' %}

{% block title %}Dashboard — JeryMotro{% endblock %}
{% block page_title %}<i class="bi bi-speedometer2"></i> Dashboard{% endblock %}

{% block content %}

{# ── Accueil / Description ───────────────────────────────── #}
<div class="dark-card mb-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(10, 17, 13, 0.92) 0%, rgba(19, 32, 24, 0.85) 100%), url('/images/sidebar_bg.png') center/cover; padding: 2.5rem; border-left: 4px solid var(--fire-orange);">
    <div class="d-flex align-items-center justify-content-between gap-4">
        <div style="z-index: 2;">
            <h3 style="color: #fff; font-weight: 800; font-size: 1.8rem; margin-bottom: 0.8rem; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
                Surveillance Stratégique — JeryMotro <i class="bi bi-fire" style="color: var(--fire-red);"></i>
            </h3>
            <p style="color: rgba(226, 237, 229, 0.9); font-size: 1.05rem; line-height: 1.6; max-width: 800px; margin-bottom: 1.2rem; text-shadow: 0 1px 4px rgba(0,0,0,0.5);">
                <strong>JeryMotro</strong> est une plateforme de télédétection spatiale dédiée à la surveillance en temps réel des feux de brousse à Madagascar. En exploitant les signaux satellitaires, le système identifie instantanément les départs de feu et coordonne les alertes critiques.
            </p>
            <div class="d-flex align-items-center gap-3">
                <span class="badge" style="background: rgba(255, 119, 0, 0.15); color: var(--fire-orange); border: 1px solid rgba(255,119,0,0.3); padding: 0.6rem 1rem; font-size: 0.85rem; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                    <i class="bi bi-shield-check"></i> Développé et Géré par <strong>Nano Banana</strong>
                </span>
            </div>
        </div>
        <div class="d-none d-lg-flex align-items-center justify-content-center" style="z-index: 2; width: 120px; height: 120px; background: rgba(0,0,0,0.3); border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); box-shadow: inset 0 0 20px rgba(255,51,51,0.2);">
            <i class="bi bi-globe-africa" style="font-size: 3.5rem; color: rgba(255,51,51,0.8); text-shadow: 0 0 20px rgba(255,51,51,0.5);"></i>
        </div>
    </div>
</div>

{# ── Stat Cards ──────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-fire"></i></div>
            <div>
                <div class="stat-val">{{ today_count }}</div>
                <div class="stat-lbl">Détections aujourd'hui</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-lightning-fill"></i></div>
            <div>
                <div class="stat-val">{{ max_frp }} <small style="font-size:.9rem">MW</small></div>
                <div class="stat-lbl">FRP max (24h)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="stat-val">{{ total_users }}</div>
                <div class="stat-lbl">Utilisateurs enregistrés</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-bell-fill"></i></div>
            <div>
                <div class="stat-val">{{ sent_alerts }}</div>
                <div class="stat-lbl">Alertes envoyées</div>
            </div>
        </div>
    </div>
</div>

{# ── Charts ──────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="dark-card">
            <div class="dark-card-header">
                <i class="bi bi-bar-chart-fill text-danger"></i>
                Détections par jour — 7 derniers jours
            </div>
            <div style="padding:1rem">
                <canvas id="dailyChart" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dark-card">
            <div class="dark-card-header">
                <i class="bi bi-pie-chart-fill text-warning"></i>
                MODIS vs VIIRS (24h)
            </div>
            <div style="padding:1rem; display:flex; align-items:center; justify-content:center; min-height:200px">
                <canvas id="sourceChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

{# ── Hotspots table ──────────────────────────────────────── #}
<div class="dark-card">
    <div class="dark-card-header" style="justify-content:space-between">
        <span><i class="bi bi-geo-alt-fill text-danger"></i> Hotspots récents (FRP > 50 MW — 48h)</span>
        <a href="{{ path('dashboard_export_pdf') }}" target="_blank" class="btn-fire btn">
            <i class="bi bi-file-earmark-pdf"></i> Exporter PDF
        </a>
    </div>

    <div style="overflow-x:auto">
        <table class="dark-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Source</th>
                    <th>Satellite</th>
                    <th>Latitude</th>
                    <th>Longitude</th>
                    <th>FRP (MW)</th>
                    <th>Risque</th>
                    <th>Date acquisition</th>
                    <th>J/N</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for d in hotspots %}
                <tr>
                    <td style="color:#4a5568">{{ d.id }}</td>
                    <td><span class="badge bg-secondary">{{ d.source }}</span></td>
                    <td>{{ d.satellite ?? '—' }}</td>
                    <td style="font-family:monospace">{{ d.latitude|number_format(4) }}</td>
                    <td style="font-family:monospace">{{ d.longitude|number_format(4) }}</td>
                    <td>
                        <strong style="color:{% if d.frp > 100 %}#ff3333{% elseif d.frp > 50 %}#ff7700{% else %}#42a5f5{% endif %}">
                            {{ d.frp|number_format(1) }}
                        </strong>
                    </td>
                    <td>
                        <span class="badge bg-{{ d.riskBadgeClass }}">{{ d.riskLabel }}</span>
                    </td>
                    <td>{{ d.acqDatetime|date('d/m/Y H:i') }}</td>
                    <td>{% if d.daynight == 'D' %}☀️{% else %}🌙{% endif %}</td>
                    <td>
                        <a href="{{ path('alert_new') }}"
                           class="btn btn-sm btn-outline-danger"
                           title="Créer une alerte">
                            <i class="bi bi-bell-fill"></i>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="10" style="text-align:center;color:#4a5568;padding:2rem">
                        <i class="bi bi-check-circle" style="font-size:1.5rem"></i><br>
                        Aucun hotspot (FRP > 50 MW) dans les dernières 48h.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#8892b0';
Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';

// ── Détections par jour ──────────────────────────────────
new Chart(document.getElementById('dailyChart'), {
    type: 'bar',
    data: {
        labels: {{ chart_labels|raw }},
        datasets: [{
            label: 'Détections',
            data:  {{ chart_counts|raw }},
            backgroundColor: 'rgba(255,51,51,0.6)',
            borderColor:     'rgba(255,51,51,1)',
            borderWidth: 1,
            borderRadius: 4,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { precision: 0 }, beginAtZero: true }
        }
    }
});

// ── MODIS vs VIIRS ───────────────────────────────────────
new Chart(document.getElementById('sourceChart'), {
    type: 'doughnut',
    data: {
        labels: {{ source_labels|raw }},
        datasets: [{
            data:            {{ source_counts|raw }},
            backgroundColor: ['rgba(255,51,51,0.7)', 'rgba(255,119,0,0.7)', 'rgba(66,165,245,0.7)'],
            borderColor:     ['#ff3333', '#ff7700', '#42a5f5'],
            borderWidth: 2,
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } }
        },
        cutout: '65%'
    }
});
</script>
{% endblock %}
